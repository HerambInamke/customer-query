    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "mongoose-delete": "^1.0.2",
    "mongoose-paginate-v2": "^1.8.3",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
